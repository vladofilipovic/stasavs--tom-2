<?xml version="1.0" encoding="UTF-8"?>
<persistence version="3.1"
    xmlns="https://jakarta.ee/xml/ns/persistence"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence
        https://jakarta.ee/xml/ns/persistence/persistence_3_1.xsd">

    <persistence-unit name="mojaPU" transaction-type="RESOURCE_LOCAL">
        <class>rs.math.oop.g16.p01.mapiranjeEntiteta.Student</class>
        <class>rs.math.oop.g16.p02.crudOperacije.Student</class>
        <class>rs.math.oop.g16.p03.relacije.Student</class>
        <class>rs.math.oop.g16.p03.relacije.Departman</class>
        <class>rs.math.oop.g16.p03.relacije.Predmet</class>
        <class>rs.math.oop.g16.p04.jpqlUpiti.Student</class>
        <class>rs.math.oop.g16.p04.jpqlUpiti.Departman</class>
        <class>rs.math.oop.g16.p04.jpqlUpiti.Predmet</class>
        <class>rs.math.oop.g16.p04.jpqlUpiti.StatusStudenta</class>
        <class>rs.math.oop.g16.p05.criteriaApi.Student</class>
        <class>rs.math.oop.g16.p05.criteriaApi.StatusStudenta</class>
        <exclude-unlisted-classes>true</exclude-unlisted-classes>

        <properties>
            <!-- H2 in-memory database, stays alive across EntityManager opens -->
            <property name="jakarta.persistence.jdbc.driver"
                      value="org.h2.Driver"/>
            <property name="jakarta.persistence.jdbc.url"
                      value="jdbc:h2:mem:mojaPU;DB_CLOSE_DELAY=-1"/>
            <property name="jakarta.persistence.jdbc.user" value="sa"/>
            <property name="jakarta.persistence.jdbc.password" value=""/>

            <!-- Schema auto-generation: create tables on start, drop on close -->
            <property name="jakarta.persistence.schema-generation.database.action"
                      value="create-drop"/>

            <!-- Hibernate dialect for H2 -->
            <property name="hibernate.dialect"
                      value="org.hibernate.dialect.H2Dialect"/>

            <!-- Show generated SQL — pedagogically important -->
            <property name="hibernate.show_sql" value="true"/>
            <property name="hibernate.format_sql" value="true"/>
        </properties>
    </persistence-unit>
</persistence>
